{
  "name": "pi-crust",
  "version": "0.3.2",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cemoody/pi-crust.git"
  },
  "homepage": "https://github.com/cemoody/pi-crust#readme",
  "bugs": {
    "url": "https://github.com/cemoody/pi-crust/issues"
  },
  "type": "module",
  "description": "Mobile-first self-hosted web control plane for many concurrent Pi coding-agent sessions.",
  "bin": {
    "pi-crust": "bin/pi-crust.mjs",
    "pi-crust-dev": "bin/pi-crust-dev.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "public",
    "index.html",
    "vite.config.ts",
    "tsconfig.json",
    "scripts"
  ],
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx src/server/http-api-server.ts",
    "dev:api:loop": "node scripts/dev-api.mjs -- npm run dev:api",
    "dev:api:loop:bare": "scripts/dev-loop.sh api 8787 -- npm run dev:api",
    "dev:web:loop": "scripts/dev-loop.sh web '' -- npm run dev -- --host 0.0.0.0",
    "dev:git-puller": "node scripts/dev-git-puller.mjs",
    "start": "node bin/pi-crust.mjs",
    "prepare": "test -f dist/index.html || vite build; node scripts/write-canonical-sentinel.mjs",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "audit:ci-tests": "node scripts/audit-ci-test-coverage.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "vitest run tests/e2e",
    "scenarios": "vitest run --config vitest.scenarios.config.ts",
    "e2e:browser": "playwright test",
    "check": "npm run typecheck && npm test && npm run e2e",
    "promo": "playwright test --config=playwright.promo.config.ts",
    "promo:gif": "node scripts/record-d3-gif.mjs",
    "promo:tour": "node scripts/record-showcase-gif.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@cemoody/pi-artifact": "github:cemoody/pi-artifact",
    "@earendil-works/pi-ai": "^0.78.0",
    "@earendil-works/pi-coding-agent": "^0.78.0",
    "@wterm/core": "^0.1.0",
    "@wterm/dom": "^0.1.0",
    "node-pty": "^1.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.21.0",
    "typebox": "^1.1.24",
    "vega-embed": "^7.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@cemoody/pi-crust-ext-artifacts": "^0.1.1",
    "@cemoody/pi-crust-ext-branching": "^0.1.1",
    "@cemoody/pi-crust-ext-pr-story": "https://github.com/cemoody/pi-crust-ext-pr-story.git#18cf7c2170640db91ed8bd682850847b58bf9154",
    "@cemoody/pi-crust-ext-presentations": "^0.1.1",
    "@cemoody/pi-crust-ext-schedule": "https://github.com/cemoody/pi-crust-ext-schedule.git#5c32c4a87863e5500c540541338db612a6823798",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.11",
    "vitest": "^4.0.0"
  }
}
