{
  "name": "pi-remote-control",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Mobile-first self-hosted web control plane for many concurrent Pi coding-agent sessions.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "vitest run tests/e2e",
    "check": "npm run typecheck && npm test && npm run e2e"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.0",
    "vite": "^8.0.11",
    "vitest": "^4.0.0"
  }
}
