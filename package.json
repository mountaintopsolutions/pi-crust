{
  "name": "pi-remote-control",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Mobile-first self-hosted web control plane for many concurrent Pi coding-agent sessions.",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx src/server/http-api-server.ts",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "vitest run tests/e2e",
    "e2e:browser": "playwright test",
    "check": "npm run typecheck && npm test && npm run e2e",
    "promo": "playwright test --config=playwright.promo.config.ts",
    "promo:gif": "node scripts/record-d3-gif.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "typebox": "^1.1.24",
    "vega-embed": "^7.1.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.11",
    "vitest": "^4.0.0"
  }
}
